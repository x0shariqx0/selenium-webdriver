pipeline {
    agent any

    stages {
        stage('Checkout Code') {
            steps {
                git 'https://github.com/YOUR_USERNAME/selenium-webdriver.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t selenium-test .'
            }
        }

        stage('Run Selenium Test') {
            steps {
                sh 'docker run --rm selenium-test'
            }
        }
    }

    post {
        always {
            sh 'docker system prune -af'
        }
    }
}
